# Agent Lab — environment configuration (copy to .env; NEVER commit real secrets).
#
# Everything runs OFFLINE with deterministic fakes when these are unset. Provide
# a value to activate the corresponding real backend automatically.

# --- OpenAI (activates real ChatOpenAI / OpenAIEmbeddings) --------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=256
LLM_TEMPERATURE=0.0

# --- Qdrant vector database (module 42; else InMemoryVectorStore) ------------
QDRANT_URL=
QDRANT_API_KEY=

# --- Neo4j graph database (module 43; else InMemoryGraphStore) ---------------
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
