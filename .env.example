# Agent Lab — environment configuration (copy to .env; NEVER commit real secrets).
#
# Everything runs OFFLINE with deterministic fakes when these are unset. Provide
# a value to activate the corresponding real backend automatically.

# --- OpenAI (activates real ChatOpenAI / OpenAIEmbeddings) --------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=256
LLM_TEMPERATURE=0.0

# --- Qdrant vector database (modules 07, 42; else InMemoryVectorStore) -------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Neo4j graph database (modules 08, 43+; else InMemoryGraphStore) ---------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
